{
  "name": "ai-skills",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate-catalog": "nx run catalog:generate-catalog",
    "validate": "nx run catalog:validate",
    "release": "nx release && pnpm run publish:dotnet",
    "release:first": "nx release --first-release && pnpm run publish:dotnet",
    "release:dry": "nx release --dry-run",
    "publish:dotnet": "VERSION=$(node -p \"require('./apps/cli-npx/package.json').version\") && dotnet pack apps/cli-dotnet/AiSkills.slnx -c Release -p:Version=\"$VERSION\" -o apps/cli-dotnet/dist && dotnet nuget push \"apps/cli-dotnet/dist/*.nupkg\" -s https://api.nuget.org/v3/index.json -k \"$NUGET_API_KEY\" --skip-duplicate"
  },
  "devDependencies": {
    "@nx/js": "^20.3.0",
    "@types/node": "^22.10.2",
    "@types/semver": "^7.5.8",
    "eslint": "^9.17.0",
    "nx": "^20.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "semver": "^7.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "nx"]
  }
}
