    "release:npm": "bash scripts/release-npm.sh",
    "release:nuget": "bash scripts/release-nuget.sh"
  },
  "devDependencies": {
    "@nx/js": "20.8.4",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.41",
    "@types/node": "22.19.21",
    "@types/semver": "7.7.1",
    "eslint": "9.39.4",
    "markdownlint-cli2": "0.14.0",
    "nx": "20.8.4",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0",
    "vitest": "2.1.9"
  },
  "dependencies": {
    "gray-matter": "4.0.3",
    "semver": "7.8.4"
  },
