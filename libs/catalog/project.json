{
  "name": "catalog",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/catalog/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/catalog/tsconfig.json"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/catalog/tsconfig.json --noEmit"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "libs/catalog"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint libs/catalog/src"
      }
    },
    "generate-catalog": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx libs/catalog/src/cli/generate.ts"
      }
    },
    "validate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx libs/catalog/src/cli/validate.ts"
      }
    }
  }
}
