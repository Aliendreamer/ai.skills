{
  "name": "install",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/install/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p libs/install/tsconfig.json" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p libs/install/tsconfig.json --noEmit" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run", "cwd": "libs/install" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint libs/install/src" }
    }
  }
}
